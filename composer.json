{
    "name": "fsteltenkamp/laravel-twcss-components",
    "description": "A Collection of TailwindCSS Components for Laravel",
    "license": "AGPL-3.0-only",
    "authors": [
        {
            "name": "Florian Steltenkamp"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Fsteltenkamp\\TwcssComponents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fsteltenkamp\\TwcssComponents\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fsteltenkamp\\TwcssComponents\\TwcssComponentsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
